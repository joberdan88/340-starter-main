<h1>
    <%= title %>
</h1>

<% if (errors && errors.length> 0) { %>
    <ul>
        <% errors.forEach(error=> { %>
            <li>
                <%= error %>
            </li>
            <% }) %>
    </ul>
    <% } %>

        <form action="/inv/update" method="post">
            <input type="hidden" name="inv_id" value="<%= inv_id %>">

            <label for="make">Make:</label>
            <input type="text" id="make" name="make" value="<%= inv_make %>" required>

            <label for="model">Model:</label>
            <input type="text" id="model" name="model" value="<%= inv_model %>" required>

            <label for="year">Year:</label>
            <input type="number" id="year" name="year" value="<%= inv_year %>" required>

            <label for="price">Price:</label>
            <input type="number" id="price" name="price" value="<%= inv_price %>" required>

            <label for="classificationList">Classification:</label>
            <%- classificationList %>

                <button type="submit">Update Vehicle</button>
        </form>
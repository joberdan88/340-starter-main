<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <header>
        <%- nav %>
    </header>

    <main>
        <h1>
            <%= title %>
        </h1>
        <% if (errors && errors.length> 0) { %>
            <ul>
                <% errors.forEach(error=> { %>
                    <li>
                        <%= error %>
                    </li>
                    <% }) %>
            </ul>
            <% } %>

                <form action="/inv/add-vehicle" method="post">
                    <label for="make">Make:</label>
                    <input type="text" id="make" name="make" value="<%= make || '' %>" required>

                    <label for="model">Model:</label>
                    <input type="text" id="model" name="model" value="<%= model || '' %>" required>

                    <label for="year">Year:</label>
                    <input type="number" id="year" name="year" value="<%= year || '' %>" required>

                    <label for="price">Price:</label>
                    <input type="number" id="price" name="price" value="<%= price || '' %>" required>

                    <label for="classification_id">Classification:</label>
                    <%- classificationList %> <!-- gerado dinamicamente pelo utilities.buildClassificationList -->

                        <button type="submit">Add Vehicle</button>
                </form>
    </main>
</body>

</html>